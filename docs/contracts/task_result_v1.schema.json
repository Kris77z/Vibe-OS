{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibe-os.local/contracts/task_result_v1.schema.json",
  "title": "TaskResultV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "artifacts", "actions", "memoryWrites", "errors"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "memoryWrites": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memoryWrite"
      }
    },
    "nextActions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": []
    },
    "errors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/error"
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["file_update", "file_create", "file_delete", "report", "command_result"]
        },
        "path": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["append", "update", "create", "delete", "notify", "noop"]
        },
        "target": {
          "type": "string"
        },
        "count": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        }
      }
    },
    "memoryWrite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "reason"],
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "enum": ["long_term_knowledge", "task_update", "session_summary", "other"]
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
